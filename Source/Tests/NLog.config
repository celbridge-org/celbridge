<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false">

  <!--
    Test-run NLog config. Overrides the one shipped with Celbridge.Logging so
    log output produced *during* a test (e.g. an [ERROR] line emitted by
    CommandService when a negative test deliberately throws) does not reach
    the test runner's stdout/stderr. On the GitHub Actions Linux runner, any
    line that surfaces on stderr is auto-annotated as "Error:" in the workflow
    log, which made expected-failure tests look like CI errors.

    Test results themselves come from NUnit/FluentAssertions/trx — those still
    print fully on failure. This config strips only the incidental service log,
    not any assertion output.
  -->

  <targets>
    <target xsi:type="Null" name="nullTarget" />
  </targets>

  <rules>
    <logger name="*" minlevel="Trace" writeTo="nullTarget" final="true" />
  </rules>
</nlog>
