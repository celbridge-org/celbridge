<UserControl
    x:Class="Celbridge.UserInterface.Views.Controls.ShortcutButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Celbridge.UserInterface.Views.Controls">

    <Button x:Name="ButtonElement"
            Width="48"
            Height="40"
            Padding="0"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Background="Transparent"
            BorderThickness="0"
            CornerRadius="4"
            Click="ButtonElement_Click">

        <controls:Icon x:Name="IconElement"
                  Symbol="Play"/>
    </Button>
</UserControl>
