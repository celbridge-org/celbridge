<UserControl
  x:Class="Celbridge.Explorer.Views.ExplorerPanel"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:Celbridge.Explorer.Views"
  xmlns:controls="using:Celbridge.WorkspaceUI.Views"
  xmlns:ui="using:Celbridge.UserInterface"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  DataContext="{x:Bind ViewModel}"
  Background="Transparent"
  ui:FocusTracking.Panel="Explorer">

  <Grid VerticalAlignment="Stretch"
        Background="Transparent">

    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Panel Header -->
    <controls:PanelHeader x:Name="PanelHeader"
                          Grid.Row="0"
                          ShowFocusIndicator="False"
                          Tapped="PanelHeader_Tapped"
                          Title="{x:Bind ViewModel.TitleText, Mode=OneWay}"/>

    <!-- Persistent Toolbar: shares the header background (one chrome band) and is divided from the tree -->
    <Border Grid.Row="1"
            Background="{ThemeResource PanelBackgroundABrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="6,2,6,2">
      <local:ExplorerToolbar x:Name="ExplorerToolbar"
                             HorizontalAlignment="Stretch"
                             NewFileClicked="ExplorerToolbar_NewFileClicked"
                             NewFolderClicked="ExplorerToolbar_NewFolderClicked"
                             CollapseFoldersClicked="ExplorerToolbar_CollapseFoldersClicked"/>
    </Border>

    <!-- Resource Tree -->
    <local:ResourceTree x:Name="ResourceTree"
                        Grid.Row="2"/>

    <!-- Notification Bar -->
    <local:ExplorerNotificationBar Grid.Row="3"/>

  </Grid>
</UserControl>
