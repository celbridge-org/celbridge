<UserControl
    x:Class="Celbridge.Explorer.Views.ResourceIcon"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Celbridge.UserInterface.Views.Controls">

    <Grid VerticalAlignment="Center">
        <!-- Folder icon (FontIcon) - shown when resource is a folder -->
        <controls:Icon x:Name="FolderIcon"
                  Symbol="FolderFilled"
                  FontSize="18"
                  Margin="0"
                  VerticalAlignment="Center"
                  Foreground="#FFCC40"
                  Visibility="Collapsed" />

        <!-- File icon (FileIcon control) - shown when resource is a file -->
        <controls:FileIcon x:Name="FileIconControl"
                           Size="18"
                           MinWidth="22"
                           Margin="0"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
    </Grid>
</UserControl>
