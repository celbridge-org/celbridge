<UserControl
  x:Class="Celbridge.Console.Views.ConsolePanel"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ic="using:Celbridge.UserInterface.Views.Controls"
  xmlns:local="using:Celbridge.Console.Views"
  xmlns:controls="using:Celbridge.WorkspaceUI.Views"
  xmlns:tracking="using:Celbridge.UserInterface"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  tracking:FocusTracking.Panel="Console">

  <Grid>
    
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Panel Header -->
    <controls:PanelHeader Grid.Row="0"
                          Panel="Console"
                          Region="Console"
                          Title="{x:Bind TitleText}"
                          Tapped="TitleBar_Tapped"
                          DoubleTapped="TitleBar_DoubleTapped">
      <controls:PanelHeader.ToolbarContent>
        <Button x:Name="MaximizeRestoreButton"
                AutomationProperties.AutomationId="console-maximize-button"
                Style="{StaticResource TransparentIconButtonStyle}"
                ToolTipService.ToolTip="{x:Bind ViewModel.MaximizeRestoreTooltip, Mode=OneWay}"
                VerticalAlignment="Center"
                Click="MaximizeRestoreButton_Click">
          <!-- Border provides accent highlight when maximized -->
          <Border Background="{x:Bind ViewModel.IsMaximizeButtonHighlighted, Mode=OneWay, Converter={StaticResource BoolToAccentColorConverter}}"
                  CornerRadius="4"
                  Padding="4">
            <ic:Icon Symbol="{x:Bind ViewModel.MaximizeRestoreIcon, Mode=OneWay}"
                     FontSize="14" />
          </Border>
        </Button>
      </controls:PanelHeader.ToolbarContent>
    </controls:PanelHeader>

    <InfoBar x:Name="ErrorInfoBar"
             Grid.Row="1"
             Severity="Error"
             IsOpen="{x:Bind ViewModel.IsErrorBannerVisible, Mode=OneWay}"
             IsClosable="False"
             Title="{x:Bind ViewModel.ErrorBannerTitle, Mode=OneWay}"
             Message="{x:Bind ViewModel.ErrorBannerMessage, Mode=OneWay}">
      <InfoBar.ActionButton>
        <Button Content="Reload Project"
                Click="{x:Bind ViewModel.OnReloadProjectClicked}"/>
      </InfoBar.ActionButton>
    </InfoBar>

    <InfoBar x:Name="ProjectChangeInfoBar"
             Grid.Row="2"
             Severity="Informational"
             IsOpen="{x:Bind ViewModel.IsProjectChangeBannerVisible, Mode=OneWay}"
             IsClosable="True"
             Title="{x:Bind ViewModel.ProjectChangeBannerTitle, Mode=OneWay}"
             Message="{x:Bind ViewModel.ProjectChangeBannerMessage, Mode=OneWay}"
             Closed="{x:Bind ViewModel.OnProjectChangeBannerClosed}">
      <InfoBar.ActionButton>
        <Button Content="Reload Project"
                Click="{x:Bind ViewModel.OnReloadProjectClicked}"/>
      </InfoBar.ActionButton>
    </InfoBar>

    <InfoBar x:Name="MigrationInfoBar"
             Grid.Row="3"
             Severity="Informational"
             IsOpen="{x:Bind ViewModel.IsMigrationBannerVisible, Mode=OneWay}"
             IsClosable="True"
             Title="{x:Bind ViewModel.MigrationBannerTitle, Mode=OneWay}"
             Message="{x:Bind ViewModel.MigrationBannerMessage, Mode=OneWay}"
             Closed="{x:Bind ViewModel.OnMigrationBannerClosed}"/>

    <InfoBar x:Name="ProjectCheckInfoBar"
             Grid.Row="4"
             Severity="Warning"
             IsOpen="{x:Bind ViewModel.IsProjectCheckBannerVisible, Mode=OneWay}"
             IsClosable="True"
             Title="{x:Bind ViewModel.ProjectCheckBannerTitle, Mode=OneWay}"
             Message="{x:Bind ViewModel.ProjectCheckBannerMessage, Mode=OneWay}"
             Closed="{x:Bind ViewModel.OnProjectCheckBannerClosed}"/>

    <!-- Container for dynamically acquired WebView2 from factory -->
    <Grid x:Name="WebViewContainer"
          AutomationProperties.AutomationId="console-input"
          Grid.Row="5"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"/>
  </Grid>
</UserControl>

