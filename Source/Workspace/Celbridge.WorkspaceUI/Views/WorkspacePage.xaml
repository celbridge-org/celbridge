<Page
  x:Class="Celbridge.WorkspaceUI.Views.WorkspacePage"
  x:Name="WorkspacePageName"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:Celbridge.WorkspaceUI.Views"
  xmlns:controls="using:Celbridge.UserInterface.Views.Controls"
  xmlns:vm="using:Celbridge.WorkspaceUI.ViewModels"
  NavigationCacheMode="Required"
  DataContext="{x:Bind ViewModel}">

  <Grid x:Name="LayoutRoot"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

    <Grid.ColumnDefinitions>
      <ColumnDefinition x:Name="PrimaryPanelColumn"
                        Width="300"
                        MinWidth="200"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition x:Name="SecondaryPanelColumn"
                        Width="300"
                        MinWidth="200"/>
    </Grid.ColumnDefinitions>

    <Grid.RowDefinitions>
      <RowDefinition x:Name="DocumentsPanelRow"
                     Height="*"/>
      <RowDefinition x:Name="ConsolePanelRow"
                     Height="200"
                     MinHeight="150"/>
    </Grid.RowDefinitions>

    <!-- Primary Panel -->
    <Grid x:Name="PrimaryPanel"
          Grid.RowSpan="2"
          MinWidth="200"
          Tag="Explorer"
          AutomationProperties.AutomationId="landmark.explorer"
          Background="{ThemeResource PanelBackgroundABrush}"
          GotFocus="Panel_GotFocus"
          PointerPressed="Panel_PointerPressed">
    </Grid>

    <!-- Documents Panel -->
    <Grid x:Name="DocumentsPanel"
          Grid.Column="1"
          Tag="Documents"
          AutomationProperties.AutomationId="landmark.documents"
          Background="{ThemeResource ApplicationBackgroundBrush}"
          GotFocus="Panel_GotFocus"
          PointerPressed="Panel_PointerPressed">
    </Grid>

    <!-- Secondary Panel -->
    <Grid x:Name="SecondaryPanel"
          Grid.Column="2"
          Grid.Row="0"
          Grid.RowSpan="2"
          MinWidth="200"
          Tag="Inspector"
          AutomationProperties.AutomationId="landmark.inspector"
          Background="{ThemeResource PanelBackgroundABrush}"
          GotFocus="Panel_GotFocus"
          PointerPressed="Panel_PointerPressed">
    </Grid>

    <!-- Console Panel -->
    <Grid x:Name="ConsolePanel"
          Grid.Column="1"
          Grid.Row="1"
          Tag="Console"
          AutomationProperties.AutomationId="landmark.console"
          Background="{ThemeResource PanelBackgroundBBrush}"
          GotFocus="Panel_GotFocus"
          PointerPressed="Panel_PointerPressed">
    </Grid>

    <!-- Grid splitters -->

    <controls:Splitter x:Name="PrimaryPanelSplitter"
                       Grid.Column="0"
                       Grid.RowSpan="2"
                       HorizontalAlignment="Right"
                       Orientation="Vertical"/>

    <controls:Splitter x:Name="SecondaryPanelSplitter"
                       Grid.Column="2"
                       Grid.RowSpan="2"
                       HorizontalAlignment="Left"
                       Orientation="Vertical"/>

    <controls:Splitter x:Name="ConsolePanelSplitter"
                       Grid.Column="1"
                       Grid.Row="1"
                       VerticalAlignment="Top"
                       Orientation="Horizontal"/>

    <!-- Agent-driven spotlight callout, driven by the app_spotlight tool. -->
    <TeachingTip x:Name="SpotlightTeachingTip"
                 Grid.RowSpan="2"
                 IsLightDismissEnabled="False"
                 Closed="SpotlightTeachingTip_Closed">
      <!--
        Fill the callout (and its tail) with the accent color so it stands out
        against the dark panels. The body and tail share these background brushes,
        so overriding them recolors the tail too; the foreground brushes switch the
        text to the on-accent colour for contrast.
      -->
      <TeachingTip.Resources>
        <StaticResource x:Key="TeachingTipBackgroundBrush"
                        ResourceKey="AccentFillColorDefaultBrush"/>
        <StaticResource x:Key="TeachingTipTransientBackground"
                        ResourceKey="AccentFillColorDefaultBrush"/>
        <StaticResource x:Key="TeachingTipForegroundBrush"
                        ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
        <StaticResource x:Key="TeachingTipTitleForegroundBrush"
                        ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
        <StaticResource x:Key="TeachingTipSubtitleForegroundBrush"
                        ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
      </TeachingTip.Resources>
    </TeachingTip>
  </Grid>
</Page>
