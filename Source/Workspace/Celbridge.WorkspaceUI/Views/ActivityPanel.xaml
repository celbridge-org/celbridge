<UserControl
    x:Class="Celbridge.WorkspaceUI.Views.ActivityPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Celbridge.UserInterface.Views.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid x:Name="LayoutRoot">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation Bar Container -->
        <Grid Grid.Column="0"
              Background="{ThemeResource PanelBackgroundABrush}"
              BorderBrush="{ThemeResource DividerBrush}"
              BorderThickness="0,0,1,0">

            <!-- Vertical Navigation View for tab selection -->
            <NavigationView x:Name="ActivityNavigation"
                             IsPaneToggleButtonVisible="False"
                             IsBackButtonVisible="Collapsed"
                             IsSettingsVisible="False"
                             PaneDisplayMode="LeftCompact"
                             CompactPaneLength="48"
                             Background="Transparent"
                             SelectionChanged="ActivityNavigation_SelectionChanged">
                <NavigationView.MenuItems>

                    <!-- Explorer -->
                    <NavigationViewItem x:Name="ExplorerNavItem"
                                        AutomationProperties.AutomationId="landmark.activity-explorer"
                                        Tag="Explorer">
                        <NavigationViewItem.Icon>
                            <controls:Icon
                                      Symbol="Folder"/>
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <!-- Search -->
                    <NavigationViewItem x:Name="SearchNavItem"
                                        AutomationProperties.AutomationId="landmark.activity-search"
                                        Tag="Search">
                        <NavigationViewItem.Icon>
                            <controls:Icon
                                      Symbol="Search"/>
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <!-- Debug -->
                    <NavigationViewItem x:Name="DebugNavItem"
                                        Tag="Debug"
                                        IsEnabled="False"
                                        Visibility="Collapsed">
                        <NavigationViewItem.Icon>
                            <controls:Icon
                                      Symbol="Bug"/>
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <!-- Source Control -->
                    <NavigationViewItem x:Name="SourceControlNavItem"
                                        Tag="SourceControl"
                                        IsEnabled="False"
                                        Visibility="Collapsed">
                        <NavigationViewItem.Icon>
                            <controls:Icon Symbol="Upload"/>
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </NavigationView.MenuItems>
            </NavigationView>
        </Grid>

        <!-- Content area for the selected panel -->
        <Grid x:Name="ContentArea"
              Grid.Column="1"
              Background="{ThemeResource PanelBackgroundABrush}">
            <ContentControl x:Name="ExplorerPanelControl"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch" />
            <ContentControl x:Name="SearchPanelControl"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Visibility="Collapsed" />
        </Grid>
    </Grid>
</UserControl>
