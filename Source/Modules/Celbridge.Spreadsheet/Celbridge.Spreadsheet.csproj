<Project Sdk="Uno.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net9.0;net9.0-windows10.0.22621;net9.0-desktop</TargetFrameworks>
    <UnoDisableVSWarnNetIsFirst>true</UnoDisableVSWarnNetIsFirst>
    <UnoSingleProject>true</UnoSingleProject>
    <OutputType>Library</OutputType>
    <GenerateLibraryLayout>true</GenerateLibraryLayout>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <UnoFeatures>
      CSharpMarkup;
      Lottie;
      Hosting;
      Toolkit;
      Logging;
      Mvvm;
      Configuration;
      Localization;
      ThemeService;
    </UnoFeatures>

  </PropertyGroup>

  <!-- Define HAS_SPREADJS_LICENSE when the generated private key file is present. -->
  <PropertyGroup Condition="Exists('$(MSBuildProjectDirectory)\SpreadsheetLicenseKeys.private.cs')">
    <DefineConstants>$(DefineConstants);HAS_SPREADJS_LICENSE</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Assets\**" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Web\**" />
    <!-- Excluding SpreadJS locale files for languages not supported by the app. -->
    <!-- These files have .ja. and .ko. in their names which the PRI indexer treats as -->
    <!-- language-qualified resources, generating PRI257/PRI263 warnings. -->
    <Content Remove="Web\SpreadJS\lib\spreadjs\scripts\resources\gc.spread.sheets.resources.ja.18.1.4.min.js" />
    <Content Remove="Web\SpreadJS\lib\spreadjs\scripts\resources\gc.spread.sheets.resources.ko.18.1.4.min.js" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Core\Celbridge.Foundation\Celbridge.Foundation.csproj" />
    <ProjectReference Include="..\..\Core\Celbridge.Utilities\Celbridge.Utilities.csproj" />
    <ProjectReference Include="..\..\Core\Celbridge.UserInterface\Celbridge.UserInterface.csproj" />
    <ProjectReference Include="..\..\Core\Celbridge.WebView\Celbridge.WebView.csproj" />
    <ProjectReference Include="..\..\Workspace\Celbridge.Documents\Celbridge.Documents.csproj" />
    <ProjectReference Include="..\..\Workspace\Celbridge.Entities\Celbridge.Entities.csproj" />
  </ItemGroup>

</Project>

