<UserControl
    x:Class="Celbridge.WebView.Views.WebViewFindBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Celbridge.UserInterface.Views.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Visibility="Collapsed">

    <Border Padding="8,6"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal"
                    Spacing="6"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
            <TextBox x:Name="FindTextBox"
                     Width="240"
                     MinHeight="32"
                     VerticalAlignment="Center"
                     KeyDown="FindTextBox_KeyDown"
                     TextChanged="FindTextBox_TextChanged" />
            <ToggleButton x:Name="MatchCaseButton"
                          Padding="8,6"
                          MinWidth="36"
                          MinHeight="32"
                          VerticalAlignment="Center"
                          Click="MatchCaseButton_Click">
                <controls:Icon Symbol="MatchCase" FontSize="14" />
            </ToggleButton>
            <TextBlock x:Name="MatchSummaryText"
                       VerticalAlignment="Center"
                       MinWidth="56"
                       Margin="4,0"
                       Visibility="Collapsed"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Button x:Name="FindPreviousButton"
                    Background="Transparent"
                    Padding="8,6"
                    MinWidth="36"
                    MinHeight="32"
                    VerticalAlignment="Center"
                    Click="FindPreviousButton_Click">
                <controls:Icon Symbol="ChevronUp" FontSize="14" />
            </Button>
            <Button x:Name="FindNextButton"
                    Background="Transparent"
                    Padding="8,6"
                    MinWidth="36"
                    MinHeight="32"
                    VerticalAlignment="Center"
                    Click="FindNextButton_Click">
                <controls:Icon Symbol="ChevronDown" FontSize="14" />
            </Button>
            <Button x:Name="FindCloseButton"
                    Background="Transparent"
                    Padding="8,6"
                    MinWidth="36"
                    MinHeight="32"
                    VerticalAlignment="Center"
                    Click="FindCloseButton_Click">
                <controls:Icon Symbol="Close" FontSize="14" />
            </Button>
        </StackPanel>
    </Border>
</UserControl>
