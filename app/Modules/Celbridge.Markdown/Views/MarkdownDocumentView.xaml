<views:DocumentView
    x:Class="Celbridge.Markdown.Views.MarkdownDocumentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:code="using:Celbridge.Code.Views"
    xmlns:views="using:Celbridge.Documents.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    DataContext="{x:Bind ViewModel}">

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <ToggleButton x:Name="PreviewToggleButton"
                              Height="32"
                              Padding="12,0"
                              ToolTipService.ToolTip="Toggle Preview (Ctrl+Shift+V)"
                              IsChecked="{x:Bind ViewModel.IsPreviewVisible, Mode=TwoWay}"
                              Click="PreviewToggleButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A1;"
                                  FontSize="14" />
                        <TextBlock Text="Preview"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </Border>

        <!-- Split Editor Control -->
        <code:SplitEditorControl x:Name="SplitEditor"
                                 Grid.Row="1"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch" />
    </Grid>
</views:DocumentView>
