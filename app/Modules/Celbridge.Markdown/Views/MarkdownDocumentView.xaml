<views:DocumentView
    x:Class="Celbridge.Markdown.Views.MarkdownDocumentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:code="using:Celbridge.Code.Views"
    xmlns:views="using:Celbridge.Documents.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    DataContext="{x:Bind ViewModel}">

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <ToggleButton x:Name="PreviewToggleButton"
                              Height="32"
                              Padding="12,0"
                              ToolTipService.ToolTip="Toggle Preview (Ctrl+Shift+V)"
                              IsChecked="{x:Bind ViewModel.IsPreviewVisible, Mode=TwoWay}"
                              Click="PreviewToggleButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A1;"
                                  FontSize="14" />
                        <TextBlock Text="Preview"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </Border>

        <!-- Editor and Preview Container -->
        <Grid x:Name="EditorContainer"
              Grid.Row="1"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="EditorColumn" Width="*" />
                <ColumnDefinition x:Name="SplitterColumn" Width="Auto" />
                <ColumnDefinition x:Name="PreviewColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <!-- Monaco Editor -->
            <code:MonacoEditorControl x:Name="MonacoEditor"
                                      Grid.Column="0"
                                      HorizontalAlignment="Stretch" />

            <!-- Splitter -->
            <Border x:Name="Splitter"
                    Grid.Column="1"
                    Width="1"
                    Background="{ThemeResource CardStrokeColorDefaultBrush}"
                    Visibility="Collapsed" />

            <!-- Preview WebView Container -->
            <Grid x:Name="PreviewContainer"
                  Grid.Column="2"
                  Visibility="Collapsed"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch" />
        </Grid>
    </Grid>
</views:DocumentView>
