<views:DocumentView
    x:Class="Celbridge.Markdown.Views.MarkdownDocumentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:code="using:Celbridge.Code.Views"
    xmlns:views="using:Celbridge.Documents.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    DataContext="{x:Bind ViewModel}">

    <Grid x:Name="EditorContainer"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <code:MonacoEditorControl x:Name="MonacoEditor"
                                  HorizontalAlignment="Stretch" />
    </Grid>
</views:DocumentView>
