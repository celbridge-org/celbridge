<views:DocumentView
    x:Class="Celbridge.Markdown.Views.MarkdownDocumentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:code="using:Celbridge.Code.Views"
    xmlns:views="using:Celbridge.Documents.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    DataContext="{x:Bind ViewModel}">

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4,16,4">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Spacing="4">
                <ToggleButton x:Name="PreviewModeButton"
                              Width="32"
                              Height="32"
                              Padding="0"
                              ToolTipService.ToolTip="{x:Bind ViewModePreviewTooltip}"
                              ToolTipService.Placement="Bottom"
                              Click="PreviewModeButton_Click">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xE736;"
                              FontSize="14" />
                </ToggleButton>
                <ToggleButton x:Name="SplitModeButton"
                              Width="32"
                              Height="32"
                              Padding="0"
                              ToolTipService.ToolTip="{x:Bind ViewModeSplitTooltip}"
                              ToolTipService.Placement="Bottom"
                              Click="SplitModeButton_Click">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xE8B2;"
                              FontSize="14" />
                </ToggleButton>
                <ToggleButton x:Name="SourceModeButton"
                              Width="32"
                              Height="32"
                              Padding="0"
                              ToolTipService.ToolTip="{x:Bind ViewModeSourceTooltip}"
                              ToolTipService.Placement="Bottom"
                              Click="SourceModeButton_Click">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xE943;"
                              FontSize="14" />
                </ToggleButton>
            </StackPanel>
        </Border>

        <!-- Split Editor Control -->
        <code:SplitCodeEditor x:Name="SplitEditor"
                              Grid.Row="1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
    </Grid>
</views:DocumentView>
